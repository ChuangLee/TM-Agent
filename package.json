{
  "name": "tm-agent",
  "version": "0.1.0",
  "description": "Precision tmux web console for controlling multiple AI agents from phone and desktop",
  "license": "MIT",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tm-agent": "dist/backend/cli.js"
  },
  "main": "dist/backend/cli.js",
  "homepage": "https://github.com/ChuangLee/TM-Agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChuangLee/TM-Agent.git"
  },
  "bugs": {
    "url": "https://github.com/ChuangLee/TM-Agent/issues"
  },
  "author": "TM-Agent contributors",
  "keywords": [
    "tmux",
    "terminal",
    "mobile",
    "touch",
    "web-terminal",
    "ssh",
    "agent",
    "ai-agent",
    "codex",
    "claude-code",
    "gemini-cli",
    "react",
    "xterm"
  ],
  "files": [
    "dist",
    "scripts/bootstrap.sh",
    "scripts/install.sh",
    "docs/deployment",
    "LICENSE",
    "SECURITY.md",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "dev": "concurrently -k -n be,fe \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "VITE_DEV_MODE=1 tsx watch src/backend/cli.ts",
    "dev:frontend": "vite --config vite.config.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:frontend": "vite build --config vite.config.ts",
    "start": "npm run build && node dist/backend/cli.js",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "hooks:install": "lefthook install"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.8",
    "@use-gesture/react": "^10.3.1",
    "@xterm/xterm": "^6.0.0",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "fast-json-patch": "^3.1.1",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.468.0",
    "mime-types": "^3.0.2",
    "motion": "^11.15.0",
    "node-pty": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.18.3",
    "yargs": "^17.7.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.35",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "lefthook": "^1.10.0",
    "prettier": "^3.4.2",
    "supertest": "^7.1.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
