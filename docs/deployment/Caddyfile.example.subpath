# /etc/caddy/Caddyfile - subpath reverse proxy for TM-Agent.
# Backend expected at: http://127.0.0.1:8767
#
# Open:
#   https://host.example/tmux/?token=<TM_AGENT_TOKEN>
#
# `handle_path` strips /tmux before forwarding. X-Forwarded-Prefix tells
# TM-Agent what public prefix to inject into <base href> for assets/API/WS.

host.example {
	encode zstd gzip

	request_body {
		max_size 20MB
	}

	redir /tmux /tmux/

	handle_path /tmux/* {
		reverse_proxy 127.0.0.1:8767 {
			header_up Host {host}
			header_up X-Forwarded-Prefix /tmux
		}
	}
}
