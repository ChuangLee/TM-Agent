# Persistent env file for the TM-Agent systemd service.
# Install at /etc/tm-agent/env with mode 600 (root:root).
#
# Required:
TM_AGENT_TOKEN=replace-with-openssl-rand-hex-16
TM_AGENT_PASSWORD=replace-with-openssl-rand-base64-12

# Optional:
#TM_AGENT_SOCKET_NAME=default
#TM_AGENT_SOCKET_PATH=/tmp/tmux-0/default
#TM_AGENT_DEBUG_LOG=/var/log/tm-agent/debug.log
#TM_AGENT_VERBOSE_DEBUG=0
#TM_AGENT_FORCE_SCRIPT_PTY=0
# Caps the session wizard's directory picker. Defaults to the service
# user's $HOME. Tighten for shared-account hosts (ADR-0017).
#TM_AGENT_WORKSPACE_ROOT=/home/youruser/repos
